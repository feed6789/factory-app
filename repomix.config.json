{
  "output": {
    "filePath": "factory-app.xml",
    "style": "xml",
    "removeComments": true,
    "showLineNumbers": false
  },
  "ignore": {
    "customPatterns": [
      "android/**",
      "ios/**",
      "web/**",
      "linux/**",
      "macos/**",
      "windows/**",
      "build/**",
      ".dart_tool/**",
      "**/*.g.dart",
      "**/*.freezed.dart",
      "assets/**",
      "pubspec.lock",
      "test/**",
      "node_modules/**",
      "**/.env*",
      "supabase/.temp/**",
      "**/*.png",
      "**/*.jpg",
      "**/*.svg",
      "**/*.ico"
    ]
  }
}