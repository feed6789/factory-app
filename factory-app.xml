  void _showManageInventoryAccessDialog(BuildContext context, WidgetRef ref) {
    showDialog(
      context: context,
      builder: (c) => AlertDialog(
        title: const Text(
          "Phân Quyền Thủ Kho",
          style: TextStyle(color: Colors.blue, fontWeight: FontWeight.bold),
        ),
        content: SizedBox(
          width: 400,
