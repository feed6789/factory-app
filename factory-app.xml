                            ScaffoldMessenger.of(
                              context,
                            ).showSnackBar(SnackBar(content: Text(msg)));
                        },
                      ),
                    ],
                  ),
                ),
              ),
            );
          },
        ),
        const Divider(height: 32, thickness: 2),
      ],
    );
  }

  @override
  Widget build(BuildContext context, WidgetRef ref) {
    final shiftData = ref.watch(shiftConfigsProvider);
