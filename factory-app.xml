              children: [
                const Icon(Icons.wifi_off, color: Colors.orange, size: 20),
                const SizedBox(width: 8),
                Expanded(
                  child: Text(
                    "Đang có $pendingCount bản ghi chờ đồng bộ lên server.",
                    style: TextStyle(
                      color: Colors.orange.shade900,
                      fontSize: 13,
