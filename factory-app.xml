  LinearGradient LinearFromTopToBottom(Color baseColor) {
    return LinearGradient(
      begin: Alignment.topCenter,
      end: Alignment.bottomCenter,
      colors: [Colors.white, baseColor.withOpacity(0.05)],
    );
